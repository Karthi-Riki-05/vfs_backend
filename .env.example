# ============================================================
# Value Charts Backend — Environment Variables
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/value_charts_db"

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-minimum-32-chars
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OAuth Providers (for NextAuth in frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AI Services
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# Firebase (FCM Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AWS S3 (File uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Email
EMAIL_FROM=noreply@valuechart.com
RESEND_API_KEY=

# Logging
LOG_LEVEL=info

# MySQL Source Databases (migration only)
MYSQL_VS_HOST=127.0.0.1
MYSQL_VS_USER=root
MYSQL_VS_PASS=
MYSQL_VS_DB=value_stream
MYSQL_ENT_DB=ent_value_chart
MYSQL_IND_DB=ind_value_chart
