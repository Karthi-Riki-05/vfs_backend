{
  "name": "value-charts-backend",
  "version": "1.0.0",
  "description": "Backend for Value Charts 2.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "prisma:generate": "npx prisma generate",
    "prisma:push": "npx prisma db push",
    "prisma:migrate": "npx prisma migrate dev",
    "migrate": "node src/utils/migrate-data.js",
    "full-migrate": "npm run prisma:push && npm run migrate",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:backup": "node scripts/db-backup.js",
    "db:restore": "node scripts/db-restore.js",
    "lint": "echo 'No linter configured'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.14.0",
    "apple-signin-auth": "^2.0.0",
    "argon2": "^0.40.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "immer": "^11.1.4",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.18.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "open-graph-scraper": "^6.11.0",
    "openai": "^6.22.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.5",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}
